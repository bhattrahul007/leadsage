POSTGRES_PASSWORD=leadspass
POSTGRES_DB=leadsdb

# ── Monitoring ───────────────────────────────────────────────
GRAFANA_PASSWORD=admin

# ── App ──────────────────────────────────────────────────────
LOG_LEVEL=INFO