# ── Search Providers (configure at least one) ──────────────────────────────
SERPER_API_KEY=
TAVILY_API_KEY=
GOOGLE_API_KEY=
GOOGLE_CX_KEY=
BING_SUBSCRIPTION_KEY=
SEARCHAPI_API_KEY=

# ── Linked Sources ──────────────────────────────────────────────────────────
# YC company list is fetched from the public yc-oss API — no key required.
# Set to override the default endpoint (e.g. local cache):
# YC_API_URL=https://yc-oss.github.io/api/companies/all.json

# GitHub org search — optional, improves rate limit from 60 to 5000 req/hr
GITHUB_TOKEN=

# Crunchbase Basic (free tier) — company search
CRUNCHBASE_API_KEY=

# ── LLM Providers ──────────────────────────────────────────────────────────
# Ollama (local):  set nothing here; configure base_url in config.json
# OpenAI
OPENAI_API_KEY=
# Groq  (fast inference — llama3, mixtral, gemma)
GROQ_API_KEY=
# Together AI
TOGETHER_API_KEY=
# Anthropic Claude
ANTHROPIC_API_KEY=

# ── Proxy Providers ─────────────────────────────────────────────────────────
BRIGHTDATA_USERNAME=
BRIGHTDATA_PASSWORD=
SMARTPROXY_USERNAME=
SMARTPROXY_PASSWORD=

# ── Database ─────────────────────────────────────────────────────────────────
POSTGRES_USER=leads
POSTGRES_PASSWORD=leadspass
POSTGRES_DB=leadsdb
POSTGRES_HOST=localhost
POSTGRES_PORT=5432
# Or use a full URL (overrides the parts above):
# DATABASE_URL=postgresql+psycopg2://leads:leadspass@localhost:5432/leadsdb

# ── Monitoring ───────────────────────────────────────────────────────────────
GRAFANA_PASSWORD=admin

# ── App ──────────────────────────────────────────────────────────────────────
LOG_LEVEL=INFO