# ── Search Providers (set at least one) ──────────────────────
SERPER_API_KEY=
TAVILY_API_KEY=
GOOGLE_API_KEY=
GOOGLE_CX_KEY=
BING_SUBSCRIPTION_KEY=
SEARCHAPI_API_KEY=

# ── LLM ──────────────────────────────────────────────────────
# For Ollama (local): set nothing, configure base_url in config.json
# For OpenAI:
OPENAI_API_KEY=

# ── Proxy Providers ──────────────────────────────────────────
# BrightData
BRIGHTDATA_USERNAME=
BRIGHTDATA_PASSWORD=

# SmartProxy
SMARTPROXY_USERNAME=
SMARTPROXY_PASSWORD=

# ── Database ─────────────────────────────────────────────────
